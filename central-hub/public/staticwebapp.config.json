{
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": ["/_next/*", "/*.{css,js,svg,png,jpg,ico,json,woff,woff2}"]
  },
  "mimeTypes": {
    ".svg": "image/svg+xml"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
