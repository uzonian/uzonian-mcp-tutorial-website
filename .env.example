# Hub module configuration (build-time, public). Copy to `.env.local` to test
# the module mount locally, or set these in your CI / Static Web App build.

# Path this module mounts at inside the central hub. Empty = domain root.
# Example: /mcp-server
NEXT_PUBLIC_BASE_PATH=

# Origin of the central hub. Powers the "All Tutorials" link and module switcher.
NEXT_PUBLIC_HUB_URL=https://uzoniandev.com
