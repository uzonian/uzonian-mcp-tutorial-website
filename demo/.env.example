# Cowork MCP Server Configuration
# Copy this to .env and fill in your values — NEVER commit .env

# Server
MCP_SERVER_NAME=cowork-mcp-server

# Salesforce
SALESFORCE_BASE_URL=https://yourorg.my.salesforce.com

# ServiceNow
SERVICENOW_BASE_URL=https://yourinstance.service-now.com

# Jira Cloud
JIRA_BASE_URL=https://yourorg.atlassian.net

# Response limits
MAX_RESPONSE_BYTES=8192
MAX_RESULTS=25
